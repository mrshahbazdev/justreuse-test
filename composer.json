{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "require": {
        "php": "^7.3|^8.0",
        "barryvdh/laravel-dompdf": "^0.9.0",
        "cartalyst/stripe-laravel": "^13.1",
        "cboden/ratchet": "^0.4.3",
        "fideloper/proxy": "^4.4",
        "firebase/php-jwt": "^6.11",
        "fruitcake/laravel-cors": "^2.0",
        "genealabs/laravel-sign-in-with-apple": "^0.5.0",
        "genealabs/laravel-socialiter": "^0.3.5",
        "guzzlehttp/guzzle": "^7.0.1",
        "intervention/image": "^2.5",
        "kalnoy/nestedset": "^5.0",
        "laravel/framework": "^8.12",
        "laravel/jetstream": "^1.6",
        "laravel/sanctum": "^2.6",
        "laravel/socialite": "^5.1",
        "laravel/tinker": "^2.5",
        "livewire/livewire": "^2.12",
        "maatwebsite/excel": "^3.1",
        "millat/laravel-hooks": "^1.2",
        "nwidart/laravel-modules": "9.0",
        "psr/simple-cache": "^1.0",
        "spatie/laravel-cookie-consent": "^3.1",
        "spatie/laravel-permission": "^3.18",
        "srmklive/paypal": "~1.0",
        "stripe/stripe-php": "^18.0"
    },
    "require-dev": {
        "facade/ignition": "^2.5",
        "fakerphp/faker": "^1.9.1",
        "laravel/sail": "^0.0.5",
        "mockery/mockery": "^1.4.2",
        "nunomaduro/collision": "^5.0",
        "phpunit/phpunit": "^9.3.3"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "symfony/thanks": true
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
	"conflict": {
    "symfony/console": "5.4.35"
  },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
			"Modules\\": "Modules/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "Simplexi\\Greetr\\": "packages/simplexi/greetr/src",
            "Plugins\\Paypal\\":"extra/plugins/paypal/src",
            "Mobileplugins\\Paypal\\":"extra/mobileplugins/mobilepaypal/src",
            "Plugins\\Stripe\\":"extra/plugins/stripe/src",
            "Twilioplugins\\Sms\\":"extra/twilioplugins/sms/src",
            "Bannerplugins\\Bannermap\\":"extra/bannerplugins/bannermap/src",
            "Postplugins\\Exchange\\":"extra/postplugins/exchange/src",
            "Postplugins\\Bannerads\\":"extra/postplugins/bannerads/src",
            "Postplugins\\Buynow\\":"extra/postplugins/buynow/src",
            "Chatplugins\\Ajaxtype\\":"extra/chatplugins/ajaxtype/src",
			"Chatplugins\\Wstype\\":"extra/chatplugins/wstype/src"
        },
          "files": [
            "app/Helpers/SettingsHelper.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    }
}
